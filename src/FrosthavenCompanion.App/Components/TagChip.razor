@* One effect-tag chip: icon + tooltip (falls back to text when we have no icon). *@
@{
    var (icon, tip) = TagIcons.Resolve(Tag);
    var opacity = Muted ? "opacity-50" : "";
}
@if (Compact)
{
    @if (icon is not null)
    {
        <img src="@icon" alt="@tip" title="@tip" class="@opacity" style="height:1.15rem; width:auto" />
    }
    else
    {
        <span class="badge text-bg-light border @opacity" title="@tip">@Tag</span>
    }
}
else
{
    <span class="d-inline-flex align-items-center gap-1 border rounded px-2 @opacity"
          style="padding-block:.15rem" title="@tip">
        @if (icon is not null)
        {
            <img src="@icon" alt="@tip" style="height:1.4rem; width:auto" />
        }
        else
        {
            <span class="small fw-semibold">@Tag</span>
        }
        @if (Count > 1)
        {
            <small class="fw-semibold">×@Count</small>
        }
    </span>
}

@code {
    [Parameter] public string Tag { get; set; } = "";
    [Parameter] public int Count { get; set; } = 1;
    [Parameter] public bool Muted { get; set; }
    [Parameter] public bool Compact { get; set; }
}
