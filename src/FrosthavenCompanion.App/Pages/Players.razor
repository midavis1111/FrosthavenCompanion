@page "/players"
@inject CampaignStore Store
@inject PerkCatalog Perks

<PageTitle>Players — Frosthaven Companion</PageTitle>

<h1>Players</h1>
<p class="text-muted" style="max-width: 42rem">
    Manage each player's character: perks now, more to come. Add or remove characters
    and set class/level on the <a href="party">Party</a> page.
</p>

@if (!loaded)
{
    <p><em>Loading…</em></p>
}
else if (Members.Count == 0)
{
    <p class="text-muted">No characters yet — add them on the <a href="party">Party</a> page.</p>
}
else
{
    @foreach (var c in Members)
    {
        <div class="card mb-3">
            <div class="card-header d-flex flex-wrap align-items-baseline gap-2">
                <strong>@(string.IsNullOrWhiteSpace(c.Name) ? "Unnamed character" : c.Name)</strong>
                <span class="text-muted small">
                    @(string.IsNullOrWhiteSpace(c.ClassName) ? "no class set" : c.ClassName) · Level @c.Level
                </span>
            </div>
            <div class="card-body">
                <h2 class="h6">Perks</h2>
                @if (Perks.Has(c.ClassName))
                {
                    <div class="small text-muted mb-2">
                        Tap a box: empty → <span class="text-success fw-semibold">✓ taken</span>
                        → <span class="text-warning fw-semibold">★ from bonus card</span> → empty.
                        <span class="ms-1">(@PerkSummary(c))</span>
                    </div>
                    @for (var pi = 0; pi < Perks.For(c.ClassName).Count; pi++)
                    {
                        var perkIndex = pi;
                        var perk = Perks.For(c.ClassName)[pi];
                        <div class="d-flex align-items-start gap-2 mb-1">
                            <div class="d-flex gap-1 flex-shrink-0">
                                @for (var bi = 0; bi < perk.Boxes; bi++)
                                {
                                    var boxIndex = bi;
                                    var st = CampaignStore.PerkState(c, perkIndex, boxIndex);
                                    <button type="button" class="btn btn-sm @PerkBoxClass(st)"
                                            style="width:1.6rem;height:1.6rem;padding:0;line-height:1"
                                            title="@PerkBoxTitle(st)"
                                            @onclick="() => CyclePerkAsync(c, perkIndex, boxIndex)">@PerkBoxGlyph(st)</button>
                                }
                            </div>
                            <span class="small"><IconText Text="@perk.Text" /></span>
                        </div>
                    }
                }
                else if (!string.IsNullOrWhiteSpace(c.ClassName))
                {
                    <p class="text-muted small mb-0">No perk list for "@c.ClassName" yet.</p>
                }
                else
                {
                    <p class="text-muted small mb-0">Set this character's class on the <a href="party">Party</a> page to track perks.</p>
                }

                @if (Perks.Masteries(c.ClassName).Count > 0)
                {
                    <h2 class="h6 mt-3">Masteries</h2>
                    @for (var mi = 0; mi < Perks.Masteries(c.ClassName).Count; mi++)
                    {
                        var masteryIndex = mi;
                        var done = CampaignStore.IsMastery(c, masteryIndex);
                        <div class="d-flex align-items-start gap-2 mb-1">
                            <button type="button" class="btn btn-sm @(done ? "btn-success" : "btn-outline-secondary") flex-shrink-0"
                                    style="width:1.6rem;height:1.6rem;padding:0;line-height:1"
                                    title="@(done ? "Completed — tap to clear" : "Not completed — tap to mark complete")"
                                    @onclick="() => ToggleMasteryAsync(c, masteryIndex)">@(done ? "✓" : "")</button>
                            <span class="small"><IconText Text="@Perks.Masteries(c.ClassName)[masteryIndex]" /></span>
                        </div>
                    }
                }
            </div>
        </div>
    }
}

@code {
    private bool loaded;

    private List<Character> Members => Store.Progress.Party;

    protected override async Task OnInitializedAsync()
    {
        await Store.LoadAsync();
        loaded = true;
    }

    private Task CyclePerkAsync(Character c, int perkIndex, int boxIndex) =>
        Store.CyclePerkAsync(c, perkIndex, boxIndex);

    private Task ToggleMasteryAsync(Character c, int index) => Store.ToggleMasteryAsync(c, index);

    private static string PerkBoxClass(PerkMark? s) => s switch
    {
        PerkMark.Taken => "btn-success",
        PerkMark.Bonus => "btn-warning",
        _ => "btn-outline-secondary",
    };

    private static string PerkBoxGlyph(PerkMark? s) => s switch
    {
        PerkMark.Taken => "✓",
        PerkMark.Bonus => "★",
        _ => "",
    };

    private static string PerkBoxTitle(PerkMark? s) => s switch
    {
        PerkMark.Taken => "Taken — tap to mark as a bonus-card perk",
        PerkMark.Bonus => "From the bonus card — tap to clear",
        _ => "Not taken — tap to take",
    };

    private string PerkSummary(Character c)
    {
        var taken = c.Perks.Count(p => p.Value == PerkMark.Taken);
        var bonus = c.Perks.Count(p => p.Value == PerkMark.Bonus);
        var total = Perks.For(c.ClassName).Sum(p => p.Boxes);
        var summary = $"{taken + bonus}/{total} perks";
        return bonus > 0 ? $"{summary}, {bonus} from bonus card" : summary;
    }
}
