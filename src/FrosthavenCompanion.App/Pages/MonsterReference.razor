@page "/monsters"
@inject MonsterCatalog Monsters
@inject MonsterCardService Cards
@inject NavigationManager Nav

<PageTitle>Monsters — Frosthaven Companion</PageTitle>

<h1>Monsters</h1>
<p class="text-muted small">
    Stats by scenario level (Normal / Elite). Range and many attack effects live on each monster's
    ability cards, so they only show here when the base stat card lists them.
    Hover a condition for what it does — see also the <a href="conditions">Conditions</a> page.
</p>

<div class="row">
    <div class="col-12 col-md-4 mb-3">
        <input class="form-control form-control-sm mb-2" placeholder="Search monsters…"
               @bind="search" @bind:event="oninput" />
        <div class="list-group" style="max-height:70vh; overflow:auto">
            @foreach (var m in Filtered)
            {
                <button class="list-group-item list-group-item-action py-1 d-flex align-items-center gap-2 @(Selected?.Name == m.Name ? "active" : "")"
                        @onclick="() => Select(m)">
                    <img src="icons/monsters/@(PortraitSlug(m.Name)).png" alt="" loading="lazy"
                         onerror="this.style.visibility='hidden'"
                         style="height:1.7rem; width:1.7rem; object-fit:cover; border-radius:.25rem; flex-shrink:0;" />
                    <span>@m.DisplayName</span>
                </button>
            }
            @if (!Filtered.Any())
            {
                <div class="text-muted small p-2">No monsters match.</div>
            }
        </div>
    </div>

    <div class="col-12 col-md-8">
        @if (Selected is null)
        {
            <p class="text-muted">Pick a monster to see its stats.</p>
        }
        else
        {
            <div class="d-flex align-items-start gap-3 mb-2">
                <img src="icons/monsters/@(PortraitSlug(Selected.Name)).png" alt="@Selected.DisplayName"
                     onerror="this.style.display='none'" loading="lazy"
                     style="height:130px; width:auto; border-radius:.5rem; flex-shrink:0;" />
                <h2 class="h4 mb-0">@Selected.DisplayName</h2>
            </div>

            @if (Selected.Immunities.Count > 0)
            {
                <div class="mb-2">
                    <span class="text-muted small me-1">Immune to:</span>
                    @foreach (var c in Selected.Immunities)
                    {
                        @CondBadge(c)
                    }
                </div>
            }

            <div class="btn-group btn-group-sm mb-3" role="group" aria-label="Scenario level">
                <span class="align-self-center text-muted small me-2">Level</span>
                @for (var i = 0; i <= 7; i++)
                {
                    var lvl = i;
                    <button type="button" class="btn @(level == lvl ? "btn-primary" : "btn-outline-primary")"
                            @onclick="() => level = lvl">@i</button>
                }
            </div>

            <MonsterStatCard Monster="Selected" Level="level" />
            <p class="text-muted small mt-2">
                The card shows all four levels in its band around the edges (corner = level); the
                table is the exact Normal / Elite numbers for level @level.
            </p>
        }
    </div>
</div>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "m")]
    public string? M { get; set; }

    private string search = "";
    private int level = 1;

    protected override Task OnInitializedAsync() => Cards.EnsureLoadedAsync();

    private MonsterStats? Selected => string.IsNullOrEmpty(M) ? null : Monsters.Find(M);

    // Portraits are filed under the base monster; scenario/section variants
    // (e.g. "frozen-corpse-scenario-118") reuse the base art. Bosses with no
    // portrait fall back to a hidden image via onerror.
    private static string PortraitSlug(string name) =>
        System.Text.RegularExpressions.Regex.Replace(name, "-(scenario|section)-.*$", "");

    private IEnumerable<MonsterStats> Filtered => string.IsNullOrWhiteSpace(search)
        ? Monsters.Monsters
        : Monsters.Monsters.Where(m => m.DisplayName.Contains(search.Trim(), StringComparison.OrdinalIgnoreCase));

    private void Select(MonsterStats m) =>
        Nav.NavigateTo($"monsters?m={Uri.EscapeDataString(m.Name)}");

    private static string Cap(string c) =>
        Conditions.Find(c)?.Name ?? (string.IsNullOrEmpty(c) ? c : char.ToUpper(c[0]) + c[1..]);

    private RenderFragment CondBadge(string cond)
    {
        var c = Conditions.Find(cond);
        return c is null
            ? @<span class="badge text-bg-light border me-1">@Cap(cond)</span>
            : @<img src="icons/conditions/@(c.Icon).png" alt="@c.Name" title="@($"{c.Name}: {c.Description}")"
                   class="me-1" style="height:1.5rem; width:auto; cursor:help" />;
    }
}
