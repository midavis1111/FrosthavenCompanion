@page "/"
@inject CampaignStore Store
@inject IJSRuntime JS
@inject MonsterCatalog Monsters

<PageTitle>Frosthaven Companion</PageTitle>

<div class="d-flex align-items-center flex-wrap gap-2 mb-3">
    <h1 class="me-auto mb-0">Scenario Tracker</h1>
    <button class="btn btn-outline-secondary btn-sm" @onclick="ExportAsync">Export backup</button>
    <label class="btn btn-outline-secondary btn-sm mb-0">
        Import backup
        <InputFile OnChange="ImportAsync" accept=".json" class="d-none" />
    </label>
</div>

@if (!loaded)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="mb-4" style="max-width: 24rem">
        <label class="form-label">Party name</label>
        <input class="form-control" value="@Store.Progress.PartyName" @onchange="OnPartyNameChanged" />
    </div>

    <details class="card mb-4" open="@(unlockError is not null)">
        <summary class="card-header" style="cursor: pointer">
            Unlock a scenario
            <span class="text-muted small">— from a personal quest, event, item, etc.</span>
        </summary>
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-6 col-md-3">
                    <label class="form-label">Scenario # (one or more)</label>
                    <input class="form-control" @bind="unlockIndex" placeholder="5, 7, 8" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Source (optional)</label>
                    <input class="form-control" @bind="unlockSource" placeholder="Blinkblade personal quest" />
                </div>
                <div class="col-6 col-md-3">
                    <button class="btn btn-primary w-100" @onclick="ManualUnlockAsync"
                            disabled="@string.IsNullOrWhiteSpace(unlockIndex)">Unlock</button>
                </div>
            </div>
            @if (unlockError is not null)
            {
                <div class="text-danger mt-2">@unlockError</div>
            }
        </div>
    </details>

    @if (lastUnlockMessage is not null)
    {
        <div class="alert alert-info d-flex justify-content-between align-items-center">
            <span>@lastUnlockMessage</span>
            <button type="button" class="btn-close" @onclick="() => lastUnlockMessage = null"></button>
        </div>
    }

    @if (importError is not null)
    {
        <div class="alert alert-danger">@importError</div>
    }

    <!-- Filter / search -->
    <div class="row g-2 mt-2 mb-1 align-items-center">
        <div class="col-12 col-md-4">
            <input class="form-control form-control-sm" placeholder="Search number, name, or text…"
                   @bind="searchText" @bind:event="oninput" />
        </div>
        <div class="col-6 col-md-2">
            <select class="form-select form-select-sm" @bind="statusFilter">
                <option value="">All statuses</option>
                <option value="Available">Available</option>
                <option value="Locked">Waiting</option>
                <option value="Completed">Completed</option>
                <option value="LockedOut">Locked out</option>
            </select>
        </div>
        <div class="col-6 col-md-2">
            <select class="form-select form-select-sm" @bind="regionFilter">
                <option value="">All regions</option>
                @foreach (var r in Regions)
                {
                    <option value="@r">@r</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-2">
            <select class="form-select form-select-sm" @bind="complexityFilter">
                <option value="">Any difficulty</option>
                @for (var i = 1; i <= 5; i++)
                {
                    <option value="@i">Complexity @i</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-2">
            <button class="btn btn-outline-secondary btn-sm w-100" @onclick="ClearFilters"
                    disabled="@(!FiltersActive)">Clear</button>
        </div>
    </div>
    @if (FiltersActive && Available.Count == 0 && Locked.Count == 0 && Completed.Count == 0 && LockedOut.Count == 0)
    {
        <p class="text-muted mt-3">No revealed scenarios match your filters.</p>
    }

    <!-- Available now: the playable frontier -->
    <h2 class="h4 mt-4">Available now</h2>
    @if (Available.Count == 0)
    {
        <p class="text-muted">Nothing available. (A fresh campaign starts with scenarios 0 and 1.)</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var v in Available)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-primary position-relative">
                        <div class="card-body d-flex flex-column">
                            @if (Store.IsManualUnlock(v.Index))
                            {
                                <button type="button"
                                        class="btn-close position-absolute top-0 end-0 m-2"
                                        style="font-size:.6rem"
                                        title="Remove this manual unlock"
                                        aria-label="Remove this manual unlock"
                                        @onclick="() => RemoveManualUnlockAsync(v.Index)"></button>
                            }
                            <h5 class="card-title pe-4">#@v.Index — @v.Name</h5>
                            <p class="card-subtitle text-muted small mb-2">
                                @(v.Definition.Hex is not null ? $"Hex {v.Definition.Hex}" : v.Definition.Group)@(v.Definition.Complexity is int cx ? $" · Complexity {cx}/5" : "")
                            </p>
                            @if (!string.IsNullOrWhiteSpace(v.Definition.Description))
                            {
                                <details class="small mb-2">
                                    <summary class="text-muted" style="cursor:pointer">Description</summary>
                                    <div class="mt-1 fst-italic">@v.Definition.Description</div>
                                </details>
                            }
                            @if (Store.UnlockExplanation(v.Index) is { } how)
                            {
                                <p class="text-muted small mb-2">@how</p>
                            }
                            @if (v.Definition.Monsters.Count > 0)
                            {
                                <details class="small mb-2">
                                    <summary class="text-muted" style="cursor:pointer">Enemies</summary>
                                    <div class="mt-1">
                                        @foreach (var (mon, i) in v.Definition.Monsters.Select((m, i) => (m, i)))
                                        {
                                            @if (i > 0)
                                            {
                                                <text>, </text>
                                            }
                                            @if (Monsters.Find(mon) is not null)
                                            {
                                                <a href="monsters?m=@Uri.EscapeDataString(mon)">@mon</a>
                                            }
                                            else
                                            {
                                                @mon
                                            }
                                        }
                                    </div>
                                </details>
                                <a class="small d-inline-block mb-2" href="scenario/@v.Index">View stat cards →</a>
                            }
                            <button class="btn btn-success mt-auto" @onclick="() => CompleteAsync(v.Index)">
                                Mark completed
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Revealed but gated by requirements -->
    @if (Locked.Count > 0)
    {
        <h2 class="h4 mt-4">Waiting on requirements</h2>
        <ul class="list-group">
            @foreach (var v in Locked)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>#@v.Index — @v.Name</span>
                    <span class="badge text-bg-warning">needs @string.Join(", ", v.Definition.Requires.Select(r => "#" + r))</span>
                </li>
            }
        </ul>
    }

    <!-- History -->
    @if (Completed.Count > 0)
    {
        <h2 class="h4 mt-4">Completed (@Completed.Count)</h2>
        <table class="table table-sm align-middle">
            <tbody>
                @foreach (var v in Completed)
                {
                    <tr>
                        <td class="text-nowrap align-top"><span class="badge text-bg-success">✓</span> #@v.Index</td>
                        <td class="w-100">
                            @v.Name
                            @if (!string.IsNullOrWhiteSpace(v.Definition.Description))
                            {
                                <details class="small">
                                    <summary class="text-muted" style="cursor:pointer">Description</summary>
                                    <div class="mt-1 fst-italic">@v.Definition.Description</div>
                                </details>
                            }
                            @if (v.Definition.Rewards.Count > 0)
                            {
                                <ul class="small mb-1 mt-1 ps-3">
                                    @foreach (var r in v.Definition.Rewards)
                                    {
                                        <li>@r</li>
                                    }
                                </ul>
                            }
                            @if (Store.UnlockExplanation(v.Index) is { } how)
                            {
                                <div class="small text-muted">@how</div>
                            }
                        </td>
                        <td class="text-muted small text-nowrap align-top">@v.CompletedOn?.ToString("yyyy-MM-dd")</td>
                        <td class="text-end align-top">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => UncompleteAsync(v.Index)">
                                Undo
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <!-- Branches not taken -->
    @if (LockedOut.Count > 0)
    {
        <details class="mt-3">
            <summary class="text-muted">Locked out by branch choices (@LockedOut.Count)</summary>
            <ul class="list-group mt-2">
                @foreach (var v in LockedOut)
                {
                    <li class="list-group-item text-muted">#@v.Index — @v.Name</li>
                }
            </ul>
        </details>
    }
}

@code {
    private bool loaded;
    private string? lastUnlockMessage;
    private string? importError;
    private string unlockIndex = "";
    private string unlockSource = "";
    private string? unlockError;

    // Filters (empty string = no filter on that axis).
    private string searchText = "";
    private string statusFilter = "";
    private string regionFilter = "";
    private string complexityFilter = "";

    private IReadOnlyList<ScenarioView> Views => Store.Views;
    private List<ScenarioView> Available => Filter(ScenarioStatus.Available);
    private List<ScenarioView> Locked => Filter(ScenarioStatus.Locked);
    private List<ScenarioView> LockedOut => Filter(ScenarioStatus.LockedOut);

    private List<ScenarioView> Completed => StatusShown(ScenarioStatus.Completed)
        ? Views.Where(v => v.Status == ScenarioStatus.Completed && Matches(v))
               .OrderByDescending(v => v.CompletedOn)
               .ToList()
        : [];

    // Distinct regions among revealed scenarios, for the region filter dropdown.
    private IEnumerable<string> Regions => Views
        .Where(v => v.Status != ScenarioStatus.Hidden && !string.IsNullOrEmpty(v.Definition.Group))
        .Select(v => v.Definition.Group!)
        .Distinct()
        .OrderBy(g => g);

    private bool FiltersActive =>
        !string.IsNullOrWhiteSpace(searchText) || statusFilter != "" || regionFilter != "" || complexityFilter != "";

    private bool StatusShown(ScenarioStatus status) =>
        statusFilter == "" || statusFilter == status.ToString();

    private bool Matches(ScenarioView v)
    {
        if (regionFilter != "" && v.Definition.Group != regionFilter) return false;
        if (complexityFilter != "" && v.Definition.Complexity?.ToString() != complexityFilter) return false;
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var hay = $"{v.Index} {v.Name} {v.Definition.Description}";
            if (hay.IndexOf(searchText.Trim(), StringComparison.OrdinalIgnoreCase) < 0) return false;
        }
        return true;
    }

    private void ClearFilters()
    {
        searchText = statusFilter = regionFilter = complexityFilter = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await Store.LoadAsync();
        loaded = true;
    }

    private List<ScenarioView> Filter(ScenarioStatus status) =>
        StatusShown(status)
            ? Views.Where(v => v.Status == status && Matches(v))
                   .OrderBy(v => v.Index, ScenarioIndexComparer.Instance)
                   .ToList()
            : [];

    private async Task OnPartyNameChanged(ChangeEventArgs e)
    {
        Store.Progress.PartyName = e.Value?.ToString() ?? "";
        await Store.SaveAsync();
    }

    private async Task CompleteAsync(string index)
    {
        var revealed = await Store.CompleteAsync(index, DateOnly.FromDateTime(DateTime.Now));
        lastUnlockMessage = revealed.Count == 0
            ? $"#{index} completed."
            : $"#{index} completed — unlocked {string.Join(", ", revealed.Select(d => $"#{d.Index} {d.Name}"))}";
    }

    private async Task UncompleteAsync(string index)
    {
        await Store.UncompleteAsync(index);
        lastUnlockMessage = null;
    }

    private async Task ManualUnlockAsync()
    {
        unlockError = null;
        var tokens = unlockIndex
            .Split([',', ' '], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(t => t.ToUpperInvariant())
            .Distinct()
            .ToList();

        var unlocked = new List<string>();
        var notFound = new List<string>();
        foreach (var idx in tokens)
        {
            try
            {
                var def = await Store.ManuallyUnlockAsync(idx, unlockSource);
                unlocked.Add($"#{def.Index} {def.Name}");
            }
            catch
            {
                notFound.Add(idx);
            }
        }

        if (unlocked.Count > 0)
        {
            lastUnlockMessage = $"Unlocked {string.Join(", ", unlocked)}.";
            unlockSource = "";
        }
        // Keep any bad entries in the box so they can be corrected.
        unlockIndex = string.Join(", ", notFound);
        unlockError = notFound.Count > 0 ? $"Not found: {string.Join(", ", notFound.Select(n => "#" + n))}." : null;
    }

    private async Task RemoveManualUnlockAsync(string index)
    {
        var name = Views.FirstOrDefault(v => v.Index == index)?.Name;
        var label = name is null ? $"#{index}" : $"#{index} {name}";
        if (await JS.InvokeAsync<bool>("confirm", $"Remove the manual unlock for {label}?"))
        {
            await Store.RemoveManualUnlockAsync(index);
        }
    }

    private async Task ExportAsync()
    {
        var fileName = $"frosthaven-{Sanitize(Store.Progress.PartyName)}.json";
        await JS.InvokeVoidAsync("frosthavenDownloadFile", fileName, "application/json", Store.Export());
    }

    private async Task ImportAsync(InputFileChangeEventArgs e)
    {
        importError = null;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024));
            await Store.ImportAsync(await reader.ReadToEndAsync());
        }
        catch (Exception ex)
        {
            importError = $"Import failed: {ex.Message}";
        }
    }

    private static string Sanitize(string name)
    {
        var safe = new string(name.Select(c => char.IsLetterOrDigit(c) ? c : '-').ToArray());
        return string.IsNullOrWhiteSpace(safe) ? "campaign" : safe.ToLowerInvariant();
    }

    // Sorts scenario indices numerically, keeping letter suffixes together (e.g. 4A before 4B).
    private sealed class ScenarioIndexComparer : IComparer<string>
    {
        public static readonly ScenarioIndexComparer Instance = new();

        public int Compare(string? x, string? y)
        {
            (int n, string s) Parse(string? v)
            {
                v ??= "";
                var digits = new string(v.TakeWhile(char.IsDigit).ToArray());
                return (int.TryParse(digits, out var n) ? n : int.MaxValue, v[digits.Length..]);
            }
            var px = Parse(x);
            var py = Parse(y);
            var byNumber = px.n.CompareTo(py.n);
            return byNumber != 0 ? byNumber : string.Compare(px.s, py.s, StringComparison.OrdinalIgnoreCase);
        }
    }
}
