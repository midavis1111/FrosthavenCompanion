@page "/character"
@inject CampaignStore Store
@inject PerkCatalog Perks
@inject CardCatalog Cards
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>My Character — Frosthaven Companion</PageTitle>

<h1>My Character</h1>

@if (!loaded)
{
    <p><em>Loading…</em></p>
}
else if (Me is null)
{
    <p class="text-muted">No characters yet — add one on the <a href="party">Party</a> page.</p>
}
else
{
    var c = Me!;

    <div class="mb-3" style="max-width: 22rem">
        <label class="form-label small text-muted">My class</label>
        <select class="form-select form-select-sm" value="@c.ClassName" @onchange="OnPickClass">
            @foreach (var cls in ClassOptions(c))
            {
                <option value="@cls" selected="@(string.Equals(cls, c.ClassName, StringComparison.OrdinalIgnoreCase))">@cls</option>
            }
            <option value="__other__">Other class…</option>
        </select>
        @if (addingClass)
        {
            <div class="input-group input-group-sm mt-2">
                <input class="form-control" placeholder="Class name" @bind="newClassName" />
                <button class="btn btn-primary" @onclick="ConfirmNewClass">Switch</button>
                <button class="btn btn-outline-secondary" @onclick="CancelNewClass">Cancel</button>
            </div>
        }
        <div class="form-text">Switching keeps each class's full sheet — switch back anytime.</div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="h5 mb-0">@(string.IsNullOrWhiteSpace(c.ClassName) ? "No class set" : c.ClassName)</span>
        </div>
        <div class="card-body">
          <div class="row g-4">
            <div class="col-12 col-lg-6">
            <div class="row g-3">
                <div class="col-12 col-md-5">
                    <label class="form-label small">Name</label>
                    <input class="form-control form-control-sm" @bind="c.Name" @bind:after="SaveAsync" placeholder="Character name" />
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label small">Level <span class="text-muted">(shared with Party)</span></label>
                    <div class="d-flex align-items-center gap-1">
                        <button class="btn btn-outline-secondary btn-sm px-2" @onclick="() => SetLevel(c, c.Level - 1)" disabled="@(c.Level <= 1)">−</button>
                        <span class="fw-bold" style="min-width:1.2rem; text-align:center">@c.Level</span>
                        <button class="btn btn-outline-secondary btn-sm px-2" @onclick="() => SetLevel(c, c.Level + 1)" disabled="@(c.Level >= 9)">+</button>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label small">XP</label>
                    <input type="number" min="0" class="form-control form-control-sm" @bind="c.Experience" @bind:after="SaveAsync" />
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label small">Gold</label>
                    <input type="number" min="0" class="form-control form-control-sm" @bind="c.Gold" @bind:after="SaveAsync" />
                </div>
            </div>

            <p class="text-muted small mt-1 mb-0">
                XP for next level (@(c.Level < 9 ? c.Level + 1 : 9)):
                <strong>@(c.Level < 9 ? Thresholds[c.Level].ToString() : "max")</strong>
            </p>

            @if (IsBlinkblade(c))
            {
                <hr />
                <h2 class="h6">Time tokens <span class="text-muted small fw-normal">(hourglass)</span></h2>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetTime(c, c.TimeTokens - 1)"
                            disabled="@(c.TimeTokens <= 0)">− Fast</button>
                    <span class="d-inline-flex align-items-center gap-1" style="min-width:3.6rem">
                        @for (var i = 0; i < c.TimeTokens; i++)
                        {
                            <img src="icons/game/time.png" alt="time token" style="height:1.7rem" />
                        }
                        @if (c.TimeTokens == 0)
                        {
                            <span class="text-muted small">none</span>
                        }
                    </span>
                    <span class="fw-bold" style="min-width:1rem">@c.TimeTokens</span>
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => SlowAsync(c)"
                            disabled="@(c.TimeTokens >= 2)">+ Slow</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoreAsync(c)">+1 more…</button>
                </div>
                <div class="form-text">Slow adds a token (max 2); Fast spends one. Use “+1 more” to go past 2 (confirms first).</div>
            }

            <hr />

            <h2 class="h6">Resources</h2>
            <div class="row row-cols-3 row-cols-sm-4 row-cols-md-5 g-2 mb-2">
                @foreach (var (slug, label) in ResourceTypes)
                {
                    var resSlug = slug;
                    <div class="col">
                        <div class="d-flex align-items-center gap-1">
                            <img src="icons/resources/@(slug).png" alt="@label" title="@label" style="height:1.4rem; width:auto" />
                            <input type="number" min="0" class="form-control form-control-sm" style="max-width:4rem"
                                   value="@Store.ResourceOf(c, slug)" @onchange="e => SetResource(c, resSlug, e)" />
                        </div>
                    </div>
                }
            </div>

            <h2 class="h6">Notes</h2>
            <textarea class="form-control form-control-sm mb-3" rows="3" @bind="c.Notes" @bind:after="SaveAsync"
                      placeholder="Items, reminders, goals…"></textarea>
            </div>

            <div class="col-12 col-lg-6">
            <h2 class="h6">Perks</h2>
            @if (Perks.Has(c.ClassName))
            {
                var b = Budget(c);
                <div class="small mb-2">
                    <div class="text-muted">
                        Tap a box: empty → <span class="text-success fw-semibold">✓ taken</span>
                        → <span class="text-warning fw-semibold">★ from bonus card</span> → empty.
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-3 mt-1">
                        <span class="d-flex align-items-center gap-1">
                            Extra perks earned
                            <input type="number" min="0" class="form-control form-control-sm" style="width:4rem"
                                   @bind="c.ExtraPerks" @bind:after="SaveAsync"
                                   title="Perks from battle goals, masteries, etc. (beyond leveling)" />
                        </span>
                        <span>Assigned <strong>@b.Assigned</strong> / earned <strong>@b.Earned</strong></span>
                        @if (b.Bonus > 0)
                        {
                            <span>+ <strong>@b.Bonus</strong> ★ bonus</span>
                        }
                        <span class="fw-semibold @ValidationCss(b.State)">@ValidationMessage(b)</span>
                    </div>
                </div>
                @for (var pi = 0; pi < Perks.For(c.ClassName).Count; pi++)
                {
                    var perkIndex = pi;
                    var perk = Perks.For(c.ClassName)[pi];
                    <div class="d-flex align-items-start gap-2 mb-1">
                        <div class="d-flex gap-1 flex-shrink-0">
                            @for (var bi = 0; bi < perk.Boxes; bi++)
                            {
                                var boxIndex = bi;
                                var st = CampaignStore.PerkState(c, perkIndex, boxIndex);
                                <button type="button" class="btn btn-sm @PerkBoxClass(st)"
                                        style="width:1.6rem;height:1.6rem;padding:0;line-height:1"
                                        title="@PerkBoxTitle(st)"
                                        @onclick="() => CyclePerkAsync(c, perkIndex, boxIndex)">@PerkBoxGlyph(st)</button>
                            }
                        </div>
                        <span class="small"><IconText Text="@perk.Text" /></span>
                    </div>
                }
            }
            else if (!string.IsNullOrWhiteSpace(c.ClassName))
            {
                <p class="text-muted small">No perk list for "@c.ClassName" yet.</p>
            }
            else
            {
                <p class="text-muted small">Set this character's class on the <a href="party">Party</a> page to track perks.</p>
            }

            @if (Perks.Masteries(c.ClassName).Count > 0)
            {
                <h2 class="h6 mt-3">Masteries</h2>
                @for (var mi = 0; mi < Perks.Masteries(c.ClassName).Count; mi++)
                {
                    var masteryIndex = mi;
                    var done = CampaignStore.IsMastery(c, masteryIndex);
                    <div class="d-flex align-items-start gap-2 mb-1">
                        <button type="button" class="btn btn-sm @(done ? "btn-success" : "btn-outline-secondary") flex-shrink-0"
                                style="width:1.6rem;height:1.6rem;padding:0;line-height:1"
                                title="@(done ? "Completed — tap to clear" : "Not completed — tap to mark complete")"
                                @onclick="() => ToggleMasteryAsync(c, masteryIndex)">@(done ? "✓" : "")</button>
                        <span class="small"><IconText Text="@Perks.Masteries(c.ClassName)[masteryIndex]" /></span>
                    </div>
                }
            }
            </div>
          </div>

            <hr />

            <h2 class="h6 mt-3">Deck</h2>
            @if (Cards.Has(c.ClassName))
            {
                var deckCards = Cards.For(c.ClassName)
                    .Where(x => CampaignStore.CardSlotOf(c, x.Id) == CardSlot.Deck)
                    .OrderBy(x => x.Initiative).ToList();
                var handSize = Cards.HandSize(c.ClassName);
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="@(deckCards.Count > handSize ? "text-danger" : deckCards.Count == handSize ? "text-success" : null)">
                        <strong>@deckCards.Count</strong> / @handSize cards
                    </span>
                    <a href="deck" class="btn btn-outline-primary btn-sm py-0">Manage deck →</a>
                </div>
                @if (deckCards.Count == 0)
                {
                    <p class="text-muted small mb-0">No cards selected — <a href="deck">build your deck →</a></p>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var card in deckCards)
                        {
                            var src = $"icons/cards/{PerkCatalog.Slugify(c.ClassName)}/{card.Image}.png";
                            @if (card.Image is not null)
                            {
                                <img src="@src" alt="@card.Name" title="@card.Name (@card.InitiativeDisplay)" loading="lazy"
                                     class="deck-thumb border rounded" style="cursor:zoom-in"
                                     @onclick="() => lightbox?.Open(src, card.Name)" />
                            }
                            else
                            {
                                <span class="badge text-bg-light border">@card.Name</span>
                            }
                        }
                    </div>
                }
            }
            else if (!string.IsNullOrWhiteSpace(c.ClassName))
            {
                <p class="text-muted small mb-0">No ability-card list for "@c.ClassName" yet.</p>
            }
        </div>
    </div>
}

<CardLightbox @ref="lightbox" />

@code {
    private bool loaded;
    private CardLightbox? lightbox;

    // Frosthaven XP thresholds for levels 1–9 (index = level-1).
    private static readonly int[] Thresholds = [0, 45, 95, 150, 210, 275, 345, 420, 500];

    private static readonly (string Slug, string Label)[] ResourceTypes =
    [
        ("lumber", "Lumber"), ("metal", "Metal"), ("hide", "Hide"),
        ("arrowvine", "Arrowvine"), ("axenut", "Axenut"), ("corpsecap", "Corpsecap"),
        ("flamefruit", "Flamefruit"), ("rockroot", "Rockroot"), ("snowthistle", "Snowthistle"),
    ];

    private static readonly string[] StartingClasses =
        ["Banner Spear", "Blinkblade", "Boneshaper", "Deathwalker", "Drifter", "Geminate"];

    private bool addingClass;
    private string newClassName = "";

    private Character? Me => Store.MyCharacter;

    protected override async Task OnInitializedAsync()
    {
        await Store.LoadAsync();
        loaded = true;
    }

    private Task SaveAsync() => Store.SaveAsync();

    private IEnumerable<string> ClassOptions(Character c) =>
        StartingClasses
            .Concat(Cards.Classes.Select(Display))
            .Concat(Store.MyClasses)
            .Append(c.ClassName)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct(StringComparer.OrdinalIgnoreCase);

    private static string Display(string slug) =>
        string.Join(" ", slug.Split('-')
            .Select(w => w.Length == 0 ? w : char.ToUpperInvariant(w[0]) + w[1..]));

    private async Task OnPickClass(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        if (value == "__other__")
        {
            addingClass = true;
            return;
        }
        addingClass = false;
        await Store.SwitchMyClassAsync(value);
    }

    private async Task ConfirmNewClass()
    {
        if (!string.IsNullOrWhiteSpace(newClassName))
            await Store.SwitchMyClassAsync(newClassName);
        addingClass = false;
        newClassName = "";
    }

    private void CancelNewClass()
    {
        addingClass = false;
        newClassName = "";
    }

    private static bool IsBlinkblade(Character c) =>
        string.Equals(c.ClassName, "Blinkblade", StringComparison.OrdinalIgnoreCase);

    private Task SetTime(Character c, int n) => Store.SetTimeTokensAsync(c, n);

    private async Task SlowAsync(Character c)
    {
        if (c.TimeTokens < 2)
            await Store.SetTimeTokensAsync(c, c.TimeTokens + 1);
    }

    private async Task MoreAsync(Character c)
    {
        var ok = await JS.InvokeAsync<bool>("confirm",
            $"You have {c.TimeTokens} time tokens. Add another beyond the usual max of 2?");
        if (ok)
            await Store.SetTimeTokensAsync(c, c.TimeTokens + 1);
    }

    private async Task SetLevel(Character c, int level)
    {
        c.Level = Math.Clamp(level, 1, 9);
        await Store.SaveAsync();
    }

    private async Task SetResource(Character c, string slug, ChangeEventArgs e)
    {
        _ = int.TryParse(e.Value?.ToString(), out var n);
        await Store.SetResourceAsync(c, slug, n);
    }

    private Task CyclePerkAsync(Character c, int perkIndex, int boxIndex) =>
        Store.CyclePerkAsync(c, perkIndex, boxIndex);

    private Task ToggleMasteryAsync(Character c, int index) => Store.ToggleMasteryAsync(c, index);

    private static string PerkBoxClass(PerkMark? s) => s switch
    {
        PerkMark.Taken => "btn-success",
        PerkMark.Bonus => "btn-warning",
        _ => "btn-outline-secondary",
    };

    private static string PerkBoxGlyph(PerkMark? s) => s switch
    {
        PerkMark.Taken => "✓",
        PerkMark.Bonus => "★",
        _ => "",
    };

    private static string PerkBoxTitle(PerkMark? s) => s switch
    {
        PerkMark.Taken => "Taken — tap to mark as a bonus-card perk",
        PerkMark.Bonus => "From the bonus card — tap to clear",
        _ => "Not taken — tap to take",
    };

    private PerkBudget Budget(Character c)
    {
        var assigned = c.Perks.Count(p => p.Value == PerkMark.Taken);
        var bonus = c.Perks.Count(p => p.Value == PerkMark.Bonus);
        return PerkRules.Budget(c.Level, c.ExtraPerks, assigned, bonus);
    }

    private static string ValidationCss(PerkBudgetState s) => s switch
    {
        PerkBudgetState.Over => "text-danger",
        PerkBudgetState.Exact => "text-success",
        _ => "text-muted",
    };

    private static string ValidationMessage(PerkBudget b) => b.State switch
    {
        PerkBudgetState.Over => $"⚠ {-b.Remaining} over your earned perks",
        PerkBudgetState.Exact => "✓ all earned perks assigned",
        _ => $"{b.Remaining} perk(s) left to assign",
    };
}
