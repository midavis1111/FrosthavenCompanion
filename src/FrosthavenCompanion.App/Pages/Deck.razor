@page "/deck"
@inject CampaignStore Store
@inject CardCatalog Cards

<PageTitle>Deck — Frosthaven Companion</PageTitle>

<h1>Deck</h1>
<p class="text-muted" style="max-width: 42rem">
    Build your scenario hand: move cards between your deck and the bench. Set class/level on the
    <a href="party">Party</a> page; full card management is on <a href="character">My Character</a>.
</p>

@if (!loaded)
{
    <p><em>Loading…</em></p>
}
else if (Me is null || !Cards.Has(Me.ClassName))
{
    <p class="text-muted">No ability cards to show. Pick your class on the <a href="party">Party</a> page.</p>
}
else
{
    var deck = DeckCards();
    var bench = BenchCards();
    var unowned = UnownedCards();
    var hand = Cards.HandSize(Me.ClassName);

    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap gap-4">
                <div>
                    <div class="text-muted small">Deck size</div>
                    <div class="h5 mb-0 @(deck.Count > hand ? "text-danger" : deck.Count == hand ? "text-success" : "")">
                        @deck.Count / @hand
                        @if (deck.Count > hand)
                        {
                            <span class="small">⚠ over hand size</span>
                        }
                    </div>
                </div>
                <div>
                    <div class="text-muted small">Levels</div>
                    <div>@(deck.Count == 0 ? "—" : LevelMix(deck))</div>
                </div>
                <div>
                    <div class="text-muted small">Initiative range</div>
                    <div>@InitiativeRange(deck)</div>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h5">Your deck (@deck.Count)</h2>
    @if (deck.Count == 0)
    {
        <p class="text-muted">No cards in your deck yet — add some from the bench below.</p>
    }
    else
    {
        <div class="d-flex flex-wrap gap-3 mb-3">
            @foreach (var card in deck)
            {
                var id = card.Id;
                <div style="width: 150px">
                    @if (card.Image is not null)
                    {
                        <img src="icons/cards/@(ClassSlug)/@(card.Image).png" alt="@card.Name" loading="lazy"
                             class="img-fluid border rounded" />
                    }
                    <div class="small fw-semibold mt-1">@card.Name</div>
                    <div class="text-muted small">Init @card.InitiativeDisplay · @LevelLabel(card.Level)</div>
                    <button class="btn btn-outline-secondary btn-sm mt-1 w-100" @onclick="() => Move(id, CardSlot.Bench)">
                        → Bench
                    </button>
                </div>
            }
        </div>
    }

    <h2 class="h5">Bench (@bench.Count)</h2>
    @if (bench.Count == 0)
    {
        <p class="text-muted">Nothing benched.</p>
    }
    else
    {
        <ul class="list-group mb-3" style="max-width: 40rem">
            @foreach (var card in bench)
            {
                var id = card.Id;
                <li class="list-group-item d-flex align-items-center gap-2">
                    <button class="btn btn-success btn-sm" @onclick="() => Move(id, CardSlot.Deck)">→ Deck</button>
                    <div class="flex-grow-1">
                        @if (card.Image is not null)
                        {
                            <details>
                                <summary class="small">@card.Name</summary>
                                <img src="icons/cards/@(ClassSlug)/@(card.Image).png" alt="@card.Name" loading="lazy"
                                     class="img-fluid border rounded mt-1" style="max-width:300px" />
                            </details>
                        }
                        else
                        {
                            <span class="small">@card.Name</span>
                        }
                    </div>
                    <span class="text-muted small">@card.InitiativeDisplay · @LevelLabel(card.Level)</span>
                    <button class="btn btn-outline-secondary btn-sm" title="Remove from owned"
                            @onclick="() => Move(id, null)">✕</button>
                </li>
            }
        </ul>
    }

    @if (unowned.Count > 0)
    {
        <details>
            <summary class="text-muted">Add cards you own (@unowned.Count not yet on deck or bench)</summary>
            <ul class="list-group mt-2" style="max-width: 40rem">
                @foreach (var card in unowned)
                {
                    var id = card.Id;
                    <li class="list-group-item d-flex align-items-center gap-2">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => Move(id, CardSlot.Bench)">+ Bench</button>
                        <span class="flex-grow-1 small">@card.Name</span>
                        <span class="text-muted small">@card.InitiativeDisplay · @LevelLabel(card.Level)</span>
                    </li>
                }
            </ul>
        </details>
    }
}

@code {
    private bool loaded;

    private Character? Me => Store.MyCharacter;
    private string ClassSlug => Me is null ? "" : PerkCatalog.Slugify(Me.ClassName);

    protected override async Task OnInitializedAsync()
    {
        await Store.LoadAsync();
        loaded = true;
    }

    private List<AbilityCard> InSlot(CardSlot? slot) => Me is null
        ? []
        : Cards.For(Me.ClassName)
            .Where(card => CampaignStore.CardSlotOf(Me, card.Id) == slot)
            .OrderBy(card => card.Initiative)
            .ToList();

    private List<AbilityCard> DeckCards() => InSlot(CardSlot.Deck);
    private List<AbilityCard> BenchCards() => InSlot(CardSlot.Bench);
    private List<AbilityCard> UnownedCards() => InSlot(null);

    private Task Move(int cardId, CardSlot? slot) => Store.SetCardSlotAsync(Me!, cardId, slot);

    private static string LevelLabel(string level) => level == "X" ? "X" : $"L{level}";

    private static string LevelMix(IEnumerable<AbilityCard> cards) =>
        string.Join(", ", cards
            .GroupBy(c => c.Level)
            .OrderBy(g => LevelOrder(g.Key))
            .Select(g => $"{LevelLabel(g.Key)}×{g.Count()}"));

    private static string InitiativeRange(IReadOnlyList<AbilityCard> deck)
    {
        if (deck.Count == 0) return "—";
        var min = deck.MinBy(c => c.Initiative)!;
        var max = deck.MaxBy(c => c.Initiative)!;
        return min.Id == max.Id ? min.InitiativeDisplay : $"{min.InitiativeDisplay} – {max.InitiativeDisplay}";
    }

    private static int LevelOrder(string level) => level switch
    {
        "1" => 0,
        "X" => 1,
        _ => int.TryParse(level, out var n) ? n : 99,
    };
}
