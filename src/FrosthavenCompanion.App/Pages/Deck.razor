@page "/deck"
@inject CampaignStore Store
@inject CardCatalog Cards

<PageTitle>Deck — Frosthaven Companion</PageTitle>

<h1>Deck</h1>
<p class="text-muted" style="max-width: 42rem">
    Build your scenario hand: tap a card to add it to your deck, tap a deck card to send it back to the bench.
    Set class/level on <a href="party">Party</a>; run the deck in <a href="play">Play</a>.
</p>

@if (!loaded)
{
    <p><em>Loading…</em></p>
}
else if (Me is null || Cards.For(Me.ClassName).Count == 0)
{
    <p class="text-muted">No ability cards to show. Pick your class on the <a href="party">Party</a> page.</p>
}
else
{
    var all = Cards.For(Me.ClassName);
    var hand = Cards.HandSize(Me.ClassName);
    var deck = all.Where(InDeck).OrderBy(c => c.Initiative).ToList();
    var bench = all.Where(c => !InDeck(c) && EffSlot(c) == CardSlot.Bench).ToList();
    var acquire = all.Where(c => EffSlot(c) is null && LevelNum(c) <= planLevel).ToList();
    var locked = all.Where(c => EffSlot(c) is null && LevelNum(c) > planLevel).ToList();
    var provided = TagCounts(deck);
    var available = AvailableTags(deck);
    var full = deck.Count >= hand;

    <div class="card mb-3 sticky-top" style="top:0; z-index:5">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                <span class="text-muted small">Planning level</span>
                <button class="btn btn-outline-secondary btn-sm px-2" @onclick="() => SetPlan(planLevel - 1)" disabled="@(planLevel <= 1)">−</button>
                <span class="fw-bold" style="min-width:1.2rem; text-align:center">@planLevel</span>
                <button class="btn btn-outline-secondary btn-sm px-2" @onclick="() => SetPlan(planLevel + 1)" disabled="@(planLevel >= 9)">+</button>
                @if (planLevel != CharLevel)
                {
                    <span class="text-muted small">planning ahead — you're level @CharLevel (this doesn't change your character)</span>
                }
                else
                {
                    <span class="text-muted small">bump this to plan a future level; it won't change your character</span>
                }
            </div>
            <div class="d-flex flex-wrap gap-4 align-items-center mb-1">
                <div>
                    <span class="text-muted small">Deck</span>
                    <span class="h5 mb-0 ms-1 @(deck.Count > hand ? "text-danger" : deck.Count == hand ? "text-success" : "")">@deck.Count / @hand</span>
                    @if (deck.Count > hand)
                    {
                        <span class="text-danger small">⚠ over hand size</span>
                    }
                </div>
                <div><span class="text-muted small">Init</span> <span class="ms-1">@InitiativeRange(deck)</span></div>
            </div>
            <div class="fw-semibold small">Provides</div>
            @if (provided.Count == 0)
            {
                <span class="text-muted small">Nothing selected yet.</span>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2 mb-1">
                    @foreach (var (tag, count) in provided.OrderByDescending(t => t.Value).ThenBy(t => t.Key))
                    {
                        <TagChip Tag="@tag" Count="@count" />
                    }
                </div>
            }
            @if (available.Count > 0)
            {
                <div class="fw-semibold small">Available to add</div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var tag in available)
                    {
                        <TagChip Tag="@tag" Muted="true" />
                    }
                </div>
            }
        </div>
    </div>

    <h2 class="h5">Your deck (@deck.Count / @hand)</h2>
    @if (deck.Count == 0)
    {
        <p class="text-muted">No cards selected yet — tap cards below to add them.</p>
    }
    else
    {
        @foreach (var g in deck.GroupBy(c => c.Level).OrderBy(g => LevelSort(g.Key)))
        {
            <div class="text-muted small fw-semibold mt-2">Level @g.Key</div>
            <div class="d-flex flex-wrap gap-3">
                @foreach (var card in g)
                {
                    var c = card;
                    <DeckCardTile Card="c" ClassSlug="@ClassSlug"
                                  OnClick="() => RemoveFromDeck(c)" OnZoom="Zoom" />
                }
            </div>
        }
    }

    <details class="mt-3" open="@(!full)">
        <summary class="fw-semibold">
            @(full ? $"Bench & available — deck full ({deck.Count}/{hand}); remove a card to swap" : "Add cards")
        </summary>

        @if (bench.Count > 0)
        {
            <h3 class="h6 mt-3">Bench <span class="text-muted fw-normal">(owned, not in deck)</span></h3>
            @foreach (var g in bench.GroupBy(c => c.Level).OrderBy(g => LevelSort(g.Key)))
            {
                <div class="text-muted small fw-semibold mt-2">Level @g.Key</div>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var card in g)
                    {
                        var c = card;
                        <DeckCardTile Card="c" ClassSlug="@ClassSlug"
                                      ShowRemove="@(!AutoOwned(c))" OnRemove="() => UnOwn(c)"
                                      OnClick="() => AddToDeck(c)" OnZoom="Zoom" />
                    }
                </div>
            }
        }

        @if (acquire.Count > 0)
        {
            <h3 class="h6 mt-3">More cards <span class="text-muted fw-normal">(level 2+, up to your planning level — tap to add to deck)</span></h3>
            @foreach (var g in acquire.GroupBy(c => c.Level).OrderBy(g => LevelSort(g.Key)))
            {
                <div class="text-muted small fw-semibold mt-2">Level @g.Key</div>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var card in g)
                    {
                        var c = card;
                        <DeckCardTile Card="c" ClassSlug="@ClassSlug" Dimmed="true"
                                      OnClick="() => AddToDeck(c)" OnZoom="Zoom" />
                    }
                </div>
            }
        }

        @if (locked.Count > 0)
        {
            <details class="mt-3">
                <summary class="text-muted">Higher levels (unlock by leveling up)</summary>
                @foreach (var g in locked.GroupBy(c => c.Level).OrderBy(g => LevelSort(g.Key)))
                {
                    <div class="text-muted small fw-semibold mt-2">Level @g.Key</div>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var card in g)
                        {
                            var c = card;
                            <DeckCardTile Card="c" ClassSlug="@ClassSlug" Locked="true" OnZoom="Zoom" />
                        }
                    </div>
                }
            </details>
        }
    </details>
}

<CardLightbox @ref="lightbox" />

@code {
    private bool loaded;
    private CardLightbox? lightbox;

    // Level to plan the deck around — starts at the character's real level but can be
    // bumped to plan a future level. Does NOT change the character (page-local only).
    private int planLevel = 1;

    private Character? Me => Store.MyCharacter;
    private string ClassSlug => Me is null ? "" : PerkCatalog.Slugify(Me.ClassName);
    private int CharLevel => Me?.Level ?? 1;

    protected override async Task OnInitializedAsync()
    {
        await Store.LoadAsync();
        planLevel = CharLevel;
        loaded = true;
    }

    private void SetPlan(int level) => planLevel = Math.Clamp(level, 1, 9);

    // Level 1 cards are always owned (your base hand); level X and 2+ must be acquired.
    private static bool AutoOwned(AbilityCard c) => c.Level == "1";

    // Effective ownership slot: stored value, or Bench for auto-owned level-1 cards, else null (unowned).
    private CardSlot? EffSlot(AbilityCard c) =>
        CampaignStore.CardSlotOf(Me!, c.Id) ?? (AutoOwned(c) ? CardSlot.Bench : null);

    private bool InDeck(AbilityCard c) => CampaignStore.CardSlotOf(Me!, c.Id) == CardSlot.Deck;

    // Level for gating (X cards are available from level 1).
    private static int LevelNum(AbilityCard c) => c.Level switch
    {
        "1" or "X" => 1,
        var l => int.TryParse(l, out var n) ? n : 99,
    };

    // Level for display order (1, X, 2..9).
    private static int LevelSort(string level) => level switch
    {
        "1" => 0,
        "X" => 1,
        var l => int.TryParse(l, out var n) ? n : 99,
    };

    private Task AddToDeck(AbilityCard c) => Store.SetCardSlotAsync(Me!, c.Id, CardSlot.Deck);
    private Task RemoveFromDeck(AbilityCard c) => Store.SetCardSlotAsync(Me!, c.Id, CardSlot.Bench);
    private Task UnOwn(AbilityCard c) => Store.SetCardSlotAsync(Me!, c.Id, null);
    private void Zoom(string src) => lightbox?.Open(src);

    private static Dictionary<string, int> TagCounts(IEnumerable<AbilityCard> cards)
    {
        var counts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        foreach (var tag in cards.SelectMany(c => c.Tags))
            counts[tag] = counts.GetValueOrDefault(tag) + 1;
        return counts;
    }

    private List<string> AvailableTags(List<AbilityCard> deck)
    {
        if (Me is null) return [];
        var inDeck = deck.SelectMany(c => c.Tags).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var deckIds = deck.Select(c => c.Id).ToHashSet();
        return Cards.For(Me.ClassName)
            .Where(c => !deckIds.Contains(c.Id) && LevelNum(c) <= planLevel)
            .SelectMany(c => c.Tags)
            .Where(t => !inDeck.Contains(t))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(t => t)
            .ToList();
    }

    private static string InitiativeRange(IReadOnlyList<AbilityCard> deck)
    {
        if (deck.Count == 0) return "—";
        var min = deck.MinBy(c => c.Initiative)!;
        var max = deck.MaxBy(c => c.Initiative)!;
        return min.Id == max.Id ? min.InitiativeDisplay : $"{min.InitiativeDisplay} – {max.InitiativeDisplay}";
    }
}
